# Copy this file to backend/.env for local development.
# Never commit backend/.env.

# Comma-separated Gemini / Google Generative AI API keys.
GEMINI_API_KEYS=replace_with_key_1,replace_with_key_2

# Optional: model fallback order when the primary model hits quota.
# GEMINI_FLASH_FALLBACK_MODELS=gemini-flash-latest,gemini-3-flash-preview,gemini-2.5-flash,gemma-4-31b-it
# GEMMA_FALLBACK_MODELS=gemini-flash-latest,gemini-3.5-flash,gemini-2.5-flash

# Optional: model routing. Defaults live in backend/model_routes.json.
# MODEL_ROUTES_FILE=/absolute/path/to/model_routes.json
# Per-agent values override AGENT_MODELS_JSON and model_routes.json.
# DEFAULT_ANALYSIS_MODEL=gemma-4-31b-it
# DEFAULT_DECISION_MODEL=gemini-3.5-flash
# CONTEXT_DIGEST_MODEL=gemma-4-31b-it
# AUDIT_MODEL=gemini-3.5-flash
# AGENT_MODELS_JSON={"1":"gemma-4-31b-it","2":"gemma-4-31b-it","3":"gemma-4-31b-it","4":"gemma-4-31b-it","5":"gemma-4-31b-it","6":"gemma-4-31b-it","7":"gemini-3.5-flash"}
# AGENT_MODEL_7=gemini-3.5-flash

# Optional: dynamic per-key rate limits for KeyRotator token buckets.
# DEFAULT_RPM_LIMIT=5
# DEFAULT_ANALYSIS_RPM_LIMIT=30
# DEFAULT_DECISION_RPM_LIMIT=5
# RPM_LIMITS_JSON={"gemma-4-31b-it":30,"gemini-3.5-flash":5}
# TPM_LIMITS_JSON={"gemma-4-31b-it":120000,"gemini-3.5-flash":32000}
# INTER_AGENT_DELAY=0
# PRIMARY_LLM_AGENT_CALL_TIMEOUT_SECONDS=360
# FALLBACK_LLM_AGENT_CALL_TIMEOUT_SECONDS=120
# LLM_SERVER_ERROR_MAX_ATTEMPTS=6
# LLM_SERVER_ERROR_RETRY_MAX_WAIT_SECONDS=45

# Optional: override generated report directory.
# OUTPUT_DIR=/absolute/path/to/output

# Optional: local SQLite cache and report retention.
# CACHE_DB_PATH=/absolute/path/to/stock_agent_cache.sqlite3
# FINANCIAL_DATA_CACHE_SECONDS=86400
# REPORT_RETENTION_DAYS=30
# REPORT_CLEANUP_INTERVAL_SECONDS=86400
# ANALYSIS_WORKER_COUNT=2
# TASK_QUEUE_BACKEND=local
# TASK_QUEUE_BACKEND=rq
# REDIS_URL=redis://localhost:6379/0
# TASK_QUEUE_NAME=stock-analysis
# RQ_JOB_TIMEOUT_SECONDS=14400
# TASK_DB_PATH=/absolute/path/to/analysis_jobs.sqlite3
# ANALYSIS_JOB_STALE_SECONDS=21600

# Optional: deployment boundary. local exposes only an ephemeral browser mutation token;
# lan/server never expose that token and require MUTATION_API_TOKEN for write APIs.
# DEPLOYMENT_MODE=local
# MUTATION_API_TOKEN=replace_with_long_random_admin_token

# Optional: external data fallback when yfinance misses key quote fields.
# FMP_API_KEY=replace_with_fmp_key
# FMP_BASE_URL=https://financialmodelingprep.com/stable
# FINMIND_API_TOKEN=replace_with_finmind_token
# FRED_API_KEY=replace_with_fred_key

# Optional: deterministic WACC/DCF defaults used by QuantEngine and financial tools.
# WACC_COST_OF_EQUITY_PCT=10.0
# WACC_COST_OF_DEBT_PCT=3.0
# WACC_TAX_RATE_PCT=20.0

# Optional: Google Custom Search for catalysts and peer discovery.
# GOOGLE_SEARCH_API_KEY=replace_with_google_search_key
# GOOGLE_CSE_ID=replace_with_google_custom_search_engine_id
# Optional: only needed when the Google API key uses HTTP Referrer restrictions.
# GOOGLE_SEARCH_REFERER=http://localhost:8080/

# Optional: alternative search providers for catalysts and peer discovery.
# Free providers gdelt, google_news_rss, and yahoo_rss run without keys; paid/keyed providers are skipped when unset.
# WEB_SEARCH_PROVIDER_ORDER=tavily,serpapi,google_news_rss,gdelt,yahoo_rss,brave
# BRAVE_SEARCH_API_KEY=replace_with_brave_search_key
# Legacy only: Bing Search APIs retired on 2025-08-11. Do not use for new setup.
# BING_SEARCH_API_KEY=replace_with_bing_search_key
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
# TAVILY_API_KEY=replace_with_tavily_key
# SERPAPI_API_KEY=replace_with_serpapi_key
