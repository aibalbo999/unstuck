        /* ─── 圖表區 ─── */
        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }
        
        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
        }
        
        .chart-card.full-width {
            grid-column: 1 / -1;
        }
        
        .chart-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .chart-canvas-wrapper {
            position: relative;
            height: 240px;
        }
        
        .chart-canvas-wrapper.tall {
            height: 300px;
        }
        
        /* ─── 護城河評分 ─── */
        .moat-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        
        .moat-scores-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .moat-score-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .moat-score-label {
            font-size: 13px;
            color: var(--text-secondary);
            width: 80px;
            flex-shrink: 0;
        }
        
        .moat-score-bar-wrapper {
            flex: 1;
            height: 8px;
            background: rgba(255,255,255,0.08);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .moat-score-bar {
            height: 100%;
            border-radius: 4px;
            transition: width 1s ease;
        }
        
        .moat-score-num {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-primary);
            width: 30px;
            text-align: right;
        }
        
        .moat-overall {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            margin-top: 12px;
        }
        
        .moat-overall-score {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
        }
        
        .moat-overall-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
        }
        
        /* ─── 目標股價 ─── */
        .price-targets-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }
        
        .price-target-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            border-width: 1px;
        }
        
        .pt-scenario {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .pt-price {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 4px;
        }
        
        .pt-pct {
            font-size: 13px;
            font-weight: 600;
        }

        /* ─── 模式 D：短線交易計畫 ─── */
        .trade-setup-dashboard {
            margin-bottom: 24px;
        }

        .trade-setup-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 14px;
        }

        .trade-setup-eyebrow {
            margin-bottom: 4px;
            color: #22c55e;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0;
        }

        .trade-setup-header h3 {
            margin: 0;
            color: var(--text-primary);
            font-size: 20px;
            line-height: 1.3;
        }

        .trade-risk-badge {
            flex: 0 0 auto;
            border: 1px solid;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
        }

        .trade-risk-high {
            border-color: rgba(239, 68, 68, 0.5);
            background: rgba(239, 68, 68, 0.12);
            color: #fca5a5;
        }

        .trade-risk-medium {
            border-color: rgba(245, 158, 11, 0.5);
            background: rgba(245, 158, 11, 0.12);
            color: #fcd34d;
        }

        .trade-risk-low {
            border-color: rgba(34, 197, 94, 0.5);
            background: rgba(34, 197, 94, 0.12);
            color: #86efac;
        }

        .trade-setup-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin: 0;
        }

        .trade-setup-card {
            min-width: 0;
            min-height: 112px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--bg-card);
            padding: 16px;
        }

        .trade-setup-card dt {
            margin-bottom: 10px;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 600;
        }

        .trade-setup-card dd {
            margin: 0;
            color: var(--text-primary);
            font-size: 18px;
            font-weight: 750;
            line-height: 1.35;
            overflow-wrap: anywhere;
        }

        .trade-direction-long {
            border-color: rgba(34, 197, 94, 0.55);
            box-shadow: inset 0 3px 0 #22c55e;
        }

        .trade-direction-short {
            border-color: rgba(239, 68, 68, 0.55);
            box-shadow: inset 0 3px 0 #ef4444;
        }

        .trade-direction-neutral {
            border-color: rgba(245, 158, 11, 0.55);
            box-shadow: inset 0 3px 0 #f59e0b;
        }

        .trade-stop-card {
            border-color: rgba(239, 68, 68, 0.72);
            background: rgba(127, 29, 29, 0.2);
        }

        .trade-stop-card dt,
        .trade-stop-card dd {
            color: #fecaca;
        }

        .trade-catalyst {
            display: grid;
            grid-template-columns: 120px minmax(0, 1fr);
            gap: 16px;
            align-items: start;
            margin-top: 12px;
            border-left: 3px solid #38bdf8;
            background: rgba(14, 116, 144, 0.12);
            padding: 14px 16px;
        }

        .trade-catalyst-label {
            color: #7dd3fc;
            font-size: 12px;
            font-weight: 700;
        }

        .trade-catalyst p {
            margin: 0;
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.6;
            overflow-wrap: anywhere;
        }

        @media (max-width: 900px) {
            .trade-setup-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 560px) {
            .trade-setup-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .trade-setup-grid {
                grid-template-columns: 1fr;
            }

            .trade-setup-card {
                min-height: 0;
            }

            .trade-catalyst {
                grid-template-columns: 1fr;
                gap: 6px;
            }
        }
