<!-- ─── 側邊導航欄 ─── -->
<nav class="sidebar">
    <div class="sidebar-logo">
        <div class="sidebar-ticker">{{ ticker }}</div>
        <div class="sidebar-name">{{ name }}</div>
    </div>
    
    <div class="sidebar-rec">
        {{ rec_icon }} {{ rec_text }}
    </div>
    
    <div class="nav-section">
        <div class="nav-section-title">分析報告</div>
        <a class="nav-item" href="#overview">
            <span class="nav-num">0</span>
            <span class="nav-label">概覽總覽</span>
        </a>
        {% for section in agent_sections %}
        <a class="nav-item" href="#section-{{ section.agent_num }}">
            <span class="nav-num">{{ section.display_num }}</span>
            <span class="nav-label">{{ section.title }}</span>
        </a>
        {% endfor %}
    </div>

    {% if next_catalysts %}
    <div class="sidebar-catalysts">
        <div class="nav-section-title">Key Catalysts to Watch</div>
        {% for catalyst in next_catalysts %}
        <div class="sidebar-catalyst">
            <strong>{{ catalyst.event_name }}</strong>
            <span>{{ catalyst.expected_timeframe }} · {{ catalyst.impact_direction }}</span>
            <p>{{ catalyst.trigger_condition }}</p>
            <button
                class="add-to-watchlist-btn"
                type="button"
                data-ticker="{{ ticker }}"
                data-pipeline="{{ pipeline_def.id }}"
                data-impact-direction="{{ catalyst.impact_direction }}"
                data-trigger-desc="{{ catalyst.trigger_condition }}"
            >Add to Radar</button>
        </div>
        {% endfor %}
    </div>
    {% endif %}
    
    <div class="sidebar-footer">
        生成日期：{{ fetch_date }}<br>
        分析耗時：{{ time_str }}<br>
        <br>
        <span class="sidebar-footer-warning">⚠ 僅供研究參考，非投資建議</span>
    </div>
</nav>
