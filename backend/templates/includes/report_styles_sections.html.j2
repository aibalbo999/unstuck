        /* ─── 內容區段 ─── */
        .content {
            padding: 48px 64px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        #overview,
        .section {
            scroll-margin-top: 20px;
        }

        .section {
            margin-bottom: 48px;
        }
        
        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }
        
        .section-num {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 800;
            color: white;
            flex-shrink: 0;
        }
        
        .section-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
        }
        
        .section-model {
            margin-left: auto;
            font-size: 11px;
            color: var(--text-muted);
            background: rgba(255,255,255,0.05);
            padding: 3px 10px;
            border-radius: 20px;
            border: 1px solid var(--border);
        }
        
        /* ─── 分析卡片 ─── */
        .analysis-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 36px 44px;
            line-height: 1.8;
            overflow: hidden;
            box-shadow: 0 4px 16px -4px rgba(0,0,0,0.03);
        }
        
        .analysis-card ol {
            padding-left: 28px;
            margin-bottom: 16px;
        }
        
        .analysis-card ol li {
            font-size: 15.5px;
            color: var(--text-secondary);
            margin-bottom: 8px;
            list-style: decimal;
        }
        
        .analysis-card h2,
        .analysis-card h3 {
            font-size: 20px;
            font-weight: 700;
            color: var(--accent-blue);
            margin: 32px 0 16px;
            padding-bottom: 8px;
            border-bottom: 1px solid rgba(37, 99, 235, 0.15);
        }
        
        .analysis-card h3 {
            font-size: 18px;
            margin: 24px 0 12px;
            border-bottom: none;
            padding-bottom: 0;
        }

        .analysis-card h2:first-child,
        .analysis-card h3:first-child { margin-top: 0; }
        
        .analysis-card h4 {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 20px 0 10px;
        }
        
        .analysis-card p {
            font-size: 15.5px;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }
        
        .analysis-card strong {
            color: var(--text-primary);
            font-weight: 600;
        }
        
        .analysis-card ul {
            padding-left: 28px;
            margin-bottom: 16px;
        }
        
        .analysis-card li {
            font-size: 15.5px;
            color: var(--text-secondary);
            margin-bottom: 8px;
            list-style: disc;
        }
        
        /* ─── 數據表格 ─── */
        .table-wrapper {
            overflow-x: auto;
            margin: 16px 0;
            border-radius: 12px;
            border: 1px solid var(--border);
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        
        .data-table th {
            background: #f1f5f9;
            color: var(--text-primary);
            font-weight: 600;
            padding: 12px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }
        
        .data-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            color: var(--text-secondary);
            white-space: nowrap;
        }
        
        .data-table tr:last-child td { border-bottom: none; }
        .data-table tr:nth-child(even) td { background: #f8fafc; }
        .data-table tr:hover td { background: #e2e8f0; }

        .scenario-bear td { color: #dc2626; }
        .scenario-base td { color: #2563eb; }
        .scenario-bull td { color: #059669; }
        .downside-section { border-left: 3px solid #ef4444; padding-left: 20px; }
        .section-lead { color: var(--text-secondary); margin: 0 0 16px; line-height: 1.7; font-size: 15px; }
        .downside-list, .highlight-list { display: grid; gap: 12px; }
        .downside-item, .highlight-item { border: 1px solid var(--border); border-radius: 12px; padding: 16px 20px; background: var(--bg-card); }
        .downside-item p { margin: 6px 0; color: var(--text-secondary); font-size: 15px; }
        .downside-item small, .peer-table small { color: var(--text-muted); }
        .severity-critical { border-color: #ef4444; background: #fef2f2; }
        .severity-high { border-color: #f97316; background: #fff7ed; }
        .highlight-item { display: grid; grid-template-columns: minmax(100px, 160px) 1fr; gap: 12px; }
        .highlight-item span { color: var(--text-secondary); font-size: 15px; }
        .target-peer td { background: #eff6ff; color: var(--text-primary); font-weight: 600; }
