    // ─── 圖表數據 ─────────────────────────────────────────
    const chartPayload = document.getElementById('report-chart-data');
    function defaultChartData() {
        return {
            years: [],
            revenue: [],
            netIncome: [],
            grossMargin: [],
            opMargin: [],
            netMargin: [],
            fcf: [],
            roe: [],
            moatLabels: [],
            moatValues: [],
            priceTargets: {},
            currentPrice: null,
            peRiver: null,
        };
    }

    function chartArray(value) {
        return Array.isArray(value) ? value : [];
    }

    function chartObject(value) {
        return value && typeof value === 'object' && !Array.isArray(value) ? value : {};
    }

    function finiteChartNumber(value) {
        if (value === null || value === undefined) return null;
        if (typeof value === 'boolean') return null;
        if (typeof value === 'string' && !value.trim()) return null;
        const number = Number(value);
        return Number.isFinite(number) ? number : null;
    }

    function chartNumberSeries(value) {
        return chartArray(value).map(item => finiteChartNumber(item));
    }

    function normalizePriceTargets(value) {
        const targets = chartObject(value);
        const normalized = {};
        Object.keys(targets).forEach(label => {
            const price = finiteChartNumber(targets[label]);
            if (price !== null) normalized[label] = price;
        });
        return normalized;
    }

    function normalizePeRiverBands(value) {
        const bands = chartObject(value);
        const normalized = {};
        Object.keys(bands).forEach(label => {
            normalized[label] = chartNumberSeries(bands[label]);
        });
        return normalized;
    }

    function normalizePeRiver(value) {
        const peRiver = chartObject(value);
        if (!Object.keys(peRiver).length) return null;
        return Object.assign({}, peRiver, {
            years: chartArray(peRiver.years),
            bands: normalizePeRiverBands(peRiver.bands),
            eps: chartNumberSeries(peRiver.eps),
        });
    }

    function normalizeChartData(parsed) {
        return Object.assign(defaultChartData(), parsed, {
            years: chartArray(parsed.years),
            revenue: chartNumberSeries(parsed.revenue),
            netIncome: chartNumberSeries(parsed.netIncome),
            grossMargin: chartNumberSeries(parsed.grossMargin),
            opMargin: chartNumberSeries(parsed.opMargin),
            netMargin: chartNumberSeries(parsed.netMargin),
            fcf: chartNumberSeries(parsed.fcf),
            roe: chartNumberSeries(parsed.roe),
            moatLabels: chartArray(parsed.moatLabels),
            moatValues: chartNumberSeries(parsed.moatValues),
            priceTargets: normalizePriceTargets(parsed.priceTargets),
            currentPrice: finiteChartNumber(parsed.currentPrice),
            peRiver: normalizePeRiver(parsed.peRiver),
        });
    }

    function readChartPayload() {
        if (!chartPayload) return defaultChartData();
        try {
            const parsed = JSON.parse(chartPayload.textContent || '{}') || {};
            if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
                return defaultChartData();
            }
            return normalizeChartData(parsed);
        } catch (_) {
            return defaultChartData();
        }
    }

    const CHART_DATA = readChartPayload();

    window.StockAgentReportTraceability = (function () {
        let payload = null;
        let tooltip = null;

        function evidencePayload() {
            if (payload) return payload;
            const el = document.getElementById('report-evidence-data');
            if (!el) return { sources: {} };
            try {
                payload = JSON.parse(el.textContent || '{}');
            } catch (_) {
                payload = { sources: {} };
            }
            return payload;
        }

        function tooltipEl() {
            if (tooltip) return tooltip;
            tooltip = document.createElement('div');
            tooltip.className = 'source-tooltip';
            tooltip.hidden = true;
            document.body.appendChild(tooltip);
            return tooltip;
        }

        function renderTooltip(source, event) {
            const el = tooltipEl();
            el.textContent = '';
            const title = document.createElement('strong');
            title.textContent = source.source || source.source_id || '資料來源';
            const meta = document.createElement('span');
            meta.textContent = `${source.source_document || '未記錄'} · ${source.status_label || source.status || 'unknown'} · ${source.fetched_at || 'N/A'}`;
            const body = document.createElement('p');
            body.textContent = source.text || source.limitation || '此來源未保存擷取文字。';
            el.append(title, meta, body);
            el.hidden = false;
            moveTooltip(event);
        }

        function moveTooltip(event) {
            if (!tooltip || tooltip.hidden || !event) return;
            if (!Number.isFinite(event.clientX) || !Number.isFinite(event.clientY)) {
                tooltip.style.left = '240px';
                tooltip.style.top = '24px';
                return;
            }
            const offset = 14;
            const x = Math.min(event.clientX + offset, window.innerWidth - tooltip.offsetWidth - offset);
            const y = Math.min(event.clientY + offset, window.innerHeight - tooltip.offsetHeight - offset);
            tooltip.style.left = `${Math.max(offset, x)}px`;
            tooltip.style.top = `${Math.max(offset, y)}px`;
        }

        function hideTooltip() {
            if (tooltip) tooltip.hidden = true;
        }

        function showFor(target, event) {
            const sourceId = target?.dataset?.sourceId;
            const source = sourceId ? evidencePayload().sources?.[sourceId] : null;
            if (!source) return hideTooltip();
            renderTooltip(source, event);
        }

        function init(root = document) {
            root.addEventListener('mouseover', event => {
                const target = event.target.closest?.('.source-citation');
                if (target) showFor(target, event);
            });
            root.addEventListener('mousemove', moveTooltip);
            root.addEventListener('mouseout', event => {
                if (event.target.closest?.('.source-citation')) hideTooltip();
            });
            root.addEventListener('focusin', event => {
                const target = event.target.closest?.('.source-citation');
                if (target) showFor(target, event);
            });
            root.addEventListener('focusout', event => {
                if (event.target.closest?.('.source-citation')) hideTooltip();
            });
        }

        return { init };
    })();

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => window.StockAgentReportTraceability.init());
    } else {
        window.StockAgentReportTraceability.init();
    }

    Chart.defaults.color = '#94a3b8';
    Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';
    Chart.defaults.font.family = "'Inter', 'Noto Sans TC', sans-serif";

    function filterNulls(labels, data) {
        const filtered = { labels: [], data: [] };
        labels.forEach((l, i) => {
            if (data[i] !== null && data[i] !== undefined) {
                filtered.labels.push(l);
                filtered.data.push(data[i]);
            }
        });
        return filtered;
    }
